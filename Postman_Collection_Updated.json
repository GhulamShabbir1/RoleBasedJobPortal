		"name": "Recruitment Portal API - Complete",
		"description": "Complete API collection for Recruitment Portal with Auth and Company modules",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "company_id",
			"value": "",
